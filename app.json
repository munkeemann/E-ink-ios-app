{
  "expo": {
    "name": "E-Cards",
    "slug": "e-cards",
    "scheme": "ecards",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/images/Logo.png",
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-router"
    ],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d0d1a"
      },
      "package": "com.anonymous.ecards"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.e-cards",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSLocalNetworkUsageDescription": "E-Cards needs local-network access to send card images to your e-ink sleeve hub on the same Wi-Fi."
      }
    },
    "newArchEnabled": false,
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e98e35bb-d4d2-4bec-9061-b9b6f338ff2d"
      }
    }
  }
}
